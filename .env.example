# ---------------------------------------------------------------------------
# Healthcare RAG Assistant — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# ---- Required ---------------------------------------------------------------

# OpenAI — used for embeddings (text-embedding-3-small) and chat (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# ---- API Authentication -----------------------------------------------------

# Comma-separated list of valid API keys for the FastAPI /query endpoint
# Example: "key-prod-abc123,key-staging-xyz789"
API_KEYS=dev-key-123

# ---- Optional — Cohere Reranking --------------------------------------------

# When set, the retriever fetches 20 candidates and reranks to top-5.
# Leave blank to use pure vector search.
COHERE_API_KEY=

# ---- Optional — Redis Cache -------------------------------------------------

# When Redis is reachable, answers are cached with a 24-hour TTL.
# Falls back to file-based cache (.cache/) when Redis is unavailable.
REDIS_URL=redis://localhost:6379/0

# Docker Compose overrides this automatically to redis://redis:6379/0
# via the environment: block in docker-compose.yml.
